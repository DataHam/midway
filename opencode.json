{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "carbohydrate-5090": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Carbohydrate (Primary Inference - RTX 5090)",
            "options": {
                "baseURL": "http://192.168.88.101:8001/v1"
            },
            "models": {
                "qwen3.5-35b-a3b": {
                    "name": "Qwen3.5 35B-A3B (UD-Q4_K_XL)",
                    "limit": {
                        "context": 262144,
                        "output": 16384
                    }
                },
                "qwen3.5-27b": {
                    "name": "Qwen3.5 27B (UD-Q6_K_XL)",
                    "limit": {
                        "context": 131072,
                        "output": 16384
                    }
                }
            }
        },
        "tower-arc": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Tower (Arc A380 GPU + 1TB RAM)",
            "options": {
                "baseURL": "http://192.168.88.100:8001/v1"
            },
            "models": {
                "qwen2.5-7b": {
                    "name": "Qwen2.5 7B Instruct Q4_K_M (Arc A380 GPU)",
                    "limit": {
                        "context": 131072,
                        "output": 8192
                    }
                },
                "qwen3.5-9b": {
                    "name": "Qwen3.5 9B Q4_K_M (Arc A380 GPU, slower)",
                    "limit": {
                        "context": 32768,
                        "output": 4096
                    }
                },
                "qwen3.5-397b": {
                    "name": "Qwen3.5 397B-A17B MoE (CPU RAM — needs all 6 shards)",
                    "limit": {
                        "context": 262144,
                        "output": 32768
                    }
                }
            }
        },
        "mac-m4": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Mac (Fast Reflection - Apple M4 MLX)",
            "options": {
                "baseURL": "http://192.168.88.111:8001/v1"
            },
            "models": {
                "qwen3.5-9b-mlx": {
                    "name": "Qwen3.5 9B (Fast Reflection Successor)",
                    "limit": {
                        "context": 32768,
                        "output": 4096
                    }
                }
            }
        }
    },
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "http://192.168.88.100:8012/mcp/sse",
            "enabled": false
        },
        "sequentialthinking": {
            "type": "remote",
            "url": "http://192.168.88.100:8013/mcp/sse",
            "enabled": false
        },
        "cluster-memory": {
            "type": "remote",
            "url": "http://tower:8014/mcp/sse",
            "enabled": false
        },
        "cluster-shell": {
            "type": "remote",
            "url": "http://tower:8015/mcp/sse",
            "enabled": false
        }
    }
}
