{
  "name": "tam-tham-website",
  "version": "1.0.0",
  "description": "Tam-Tham professional website",
  "private": true,
  "scripts": {
    "dev": "postcss src/css/input.css -o static/css/styles.css --watch",
    "build": "mkdir -p public/css && postcss src/css/input.css -o public/css/styles.css && cp *.html public/ && cp -r assets public/ && cp staticwebapp.config.json public/ && ./scripts/inject-secrets.sh",
    "optimize-images": "node scripts/optimize-images.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@azure/functions": "^4.11.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/node": "^4.2.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.2.0",
    "vitest": "^4.1.0"
  }
}
